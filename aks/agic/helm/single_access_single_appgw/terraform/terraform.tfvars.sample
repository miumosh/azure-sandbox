# Azure Subscription ID
subscription_id = "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx" ### 要更新 # az account show --query id -o tsv

# Azure Region
location = "japaneast"

# 自分のグローバル IP (SSH 許可対象)
my_public_ip = "x.x.x.x/32" ### 要更新 # curl ifconfig.me

# Test VM 認証情報 (検証用ハードコード — 本番環境では使用しないこと)
vm_admin_username = "azureuser"
vm_admin_password = "CHANGE_ME" ### 要更新
